# Service networking
HOST=0.0.0.0
PORT=4040

# Auth between dashboard and service
GEN_SERVICE_TOKEN=change-me

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Muapi provider
MUAPI_BASE_URL=https://api.muapi.ai
MUAPI_API_KEY=

# Optional: use same DB as kpop-dashboard if/when service DB writes are enabled
KPOP_PRISMA_DATABASE_URL=

# Dashboard internal worker endpoint (used by queue worker)
DASHBOARD_BASE_URL=http://127.0.0.1:3001
GEN_WORKER_TOKEN=

# Recovery sweep tuning (adaptive backoff)
RECOVERY_SWEEP_MIN_MS=15000
RECOVERY_SWEEP_MAX_MS=300000
RECOVERY_SWEEP_IDLE_GUARD_MS=30000
